---
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import SEO from '../components/SEO.astro';
---

<SEO 
  title="Login - ZEFI Solutions"
  description="Faça login na ZEFI Solutions para acessar downloads exclusivos de Free Fire mods e cheats."
  keywords="login zefi, acesso zefi, zefi solutions login"
/>
<GoogleAnalytics />

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - ZEFI</title>
  <style>
    :root {
      --theme-primary: #42467e;
      --theme-primary-hover: #5458a0;
      --theme-on-primary: #fff;
      --theme-bg: #1b191d;
      --theme-on-bg: #b0afb0;
      --theme-surface-1: #1f1d21;
      --theme-on-surface-1: #b0afb0;
      --theme-surface-2: #232127;
      --theme-on-surface-2: #b0afb0;
      --theme-text-secondary: #454349;
      --theme-border-color: #222224;
    }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="login-card">
        <div class="login-header">
          <div class="login-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515a.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0a12.64 12.64 0 0 0-.617-1.25a.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057a19.9 19.9 0 0 0 5.993 3.03a.078.078 0 0 0 .084-.028a14.09 14.09 0 0 0 1.226-1.994a.076.076 0 0 0-.041-.106a13.107 13.107 0 0 1-1.872-.892a.077.077 0 0 1-.008-.128a10.2 10.2 0 0 0 .372-.292a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127a12.299 12.299 0 0 1-1.873.892a.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028a19.839 19.839 0 0 0 6.002-3.03a.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419c0-1.333.956-2.419 2.157-2.419c1.21 0 2.176 1.096 2.157 2.42c0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419c0-1.333.955-2.419 2.157-2.419c1.21 0 2.176 1.096 2.157 2.42c0 1.333-.946 2.418-2.157 2.418z"/>
            </svg>
          </div>
          <h1>Login</h1>
          <p>Entre com seu Discord ID</p>
        </div>

        <form id="loginForm" class="login-form">
          <div class="form-group">
            <label for="discordId">Discord ID</label>
            <input 
              type="text" 
              id="discordId" 
              name="discordId" 
              placeholder="Digite seu Discord ID"
              required
            />
          </div>

          <div class="form-group">
            <label for="password">Senha</label>
            <input 
              type="password" 
              id="password" 
              name="password" 
              placeholder="Digite sua senha"
              required
            />
          </div>

          <button type="submit" class="login-button" id="loginButton">
            <span class="button-text">Entrar</span>
            <span class="button-loader" style="display: none;">
              <svg class="spinner" viewBox="0 0 50 50">
                <circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle>
              </svg>
            </span>
          </button>

          <div id="errorMessage" class="error-message" style="display: none;"></div>
        </form>

        <div class="login-footer">
          <p>Primeira vez aqui? <a href="/register" class="register-link">Criar conta</a></p>
          <p class="help-text">Não tem acesso? Entre em contato com o suporte</p>
        </div>
      </div>
    </div>
  </div>
</body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html, body {
    height: 100%;
    width: 100%;
    overflow: hidden;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
  }

  body {
    background: var(--theme-bg);
    color: var(--theme-on-bg);
  }

  .login-container {
    min-height: 100vh;
    height: 100vh;
    width: 100vw;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: var(--theme-bg);
  }

  .login-card {
    background: var(--theme-surface-1);
    border: 1px solid var(--theme-border-color);
    border-radius: 12px;
    padding: 3rem;
    max-width: 450px;
    width: 100%;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .login-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .login-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 1.5rem;
    background: rgba(66, 70, 126, 0.15);
    border: 2px solid rgba(66, 70, 126, 0.3);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--theme-primary);
  }

  .login-icon svg {
    width: 36px;
    height: 36px;
  }

  .login-header h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    color: var(--theme-on-surface-1);
  }

  .login-header p {
    color: var(--theme-text-secondary);
    font-size: 0.95rem;
  }

  .login-form {
    margin-bottom: 1.5rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--theme-on-surface-1);
    font-weight: 500;
    font-size: 0.9rem;
  }

  .form-group input {
    width: 100%;
    padding: 0.875rem 1rem;
    background: var(--theme-surface-2);
    border: 1px solid var(--theme-border-color);
    border-radius: 8px;
    color: var(--theme-on-surface-2);
    font-size: 1rem;
    transition: all 0.2s ease;
    box-sizing: border-box;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--theme-primary);
    box-shadow: 0 0 0 3px rgba(66, 70, 126, 0.1);
  }

  .form-group input::placeholder {
    color: var(--theme-text-secondary);
  }

  .login-button {
    width: 100%;
    padding: 0.875rem;
    background: var(--theme-primary);
    color: var(--theme-on-primary);
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .login-button:hover {
    background: var(--theme-primary-hover);
    transform: translateY(-1px);
    box-shadow: 0 6px 24px rgba(66, 70, 126, 0.3);
  }

  .login-button:active {
    transform: translateY(0);
  }

  .login-button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .spinner {
    animation: rotate 2s linear infinite;
    width: 20px;
    height: 20px;
  }

  .spinner .path {
    stroke: var(--theme-on-primary);
    stroke-linecap: round;
    animation: dash 1.5s ease-in-out infinite;
  }

  @keyframes rotate {
    100% {
      transform: rotate(360deg);
    }
  }

  @keyframes dash {
    0% {
      stroke-dasharray: 1, 150;
      stroke-dashoffset: 0;
    }
    50% {
      stroke-dasharray: 90, 150;
      stroke-dashoffset: -35;
    }
    100% {
      stroke-dasharray: 90, 150;
      stroke-dashoffset: -124;
    }
  }

  .error-message {
    margin-top: 1rem;
    padding: 0.875rem;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 8px;
    color: #ef4444;
    font-size: 0.9rem;
    text-align: center;
  }

  .login-footer {
    text-align: center;
    padding-top: 1.5rem;
    border-top: 1px solid var(--theme-border-color);
  }

  .login-footer p {
    color: var(--theme-text-secondary);
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
  }

  .login-footer p:last-child {
    margin-bottom: 0;
  }

  .register-link {
    color: var(--theme-primary);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .register-link:hover {
    color: var(--theme-primary-hover);
    text-decoration: underline;
  }

  .help-text {
    font-size: 0.8rem !important;
    margin-top: 0.75rem !important;
  }
</style>

<script>
  const form = document.getElementById('loginForm') as HTMLFormElement;
  const button = document.getElementById('loginButton') as HTMLButtonElement;
  const buttonText = button.querySelector('.button-text') as HTMLElement;
  const buttonLoader = button.querySelector('.button-loader') as HTMLElement;
  const errorMessage = document.getElementById('errorMessage') as HTMLElement;
  const discordIdInput = document.getElementById('discordId') as HTMLInputElement;

  // Carregar Discord ID salvo
  const savedDiscordId = localStorage.getItem('discord_id');
  if (savedDiscordId) {
    discordIdInput.value = savedDiscordId;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const discordId = discordIdInput.value.trim();
    
    if (!discordId) {
      showError('Por favor, digite seu Discord ID');
      return;
    }

    // Mostrar loading
    button.disabled = true;
    buttonText.style.display = 'none';
    buttonLoader.style.display = 'block';
    errorMessage.style.display = 'none';

    try {
      // Chamar API de login
      const response = await fetch('/api/auth/login', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ discord_id: discordId, password: password.value }),
      });

      const data = await response.json();

      if (data.success) {
        // Salvar Discord ID
        localStorage.setItem('discord_id', discordId);
        localStorage.setItem('auth_token', data.token);
        localStorage.setItem('user_data', JSON.stringify(data.user));
        
        // Redirecionar para downloads
        window.location.href = '/downloads';
      } else {
        showError(data.message || 'Erro ao fazer login. Verifique seu Discord ID.');
      }
    } catch (error) {
      showError('Erro de conexão. Tente novamente.');
      console.error('Login error:', error);
    } finally {
      // Esconder loading
      button.disabled = false;
      buttonText.style.display = 'block';
      buttonLoader.style.display = 'none';
    }
  });

  function showError(message: string) {
    errorMessage.textContent = message;
    errorMessage.style.display = 'block';
  }
</script>

