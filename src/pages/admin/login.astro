---
import SEO from '../../components/SEO.astro';
import GoogleAnalytics from '../../components/GoogleAnalytics.astro';

// Se já tem token no localStorage, redireciona para dashboard
const cookies = Astro.request.headers.get('cookie');
const hasToken = cookies?.includes('admin_token');

if (hasToken) {
  return Astro.redirect('/admin/versions');
}
---

<SEO 
  title="Admin Login - Fertel"
  description="Painel de login do administrador"
  keywords="admin, login, fertel"
/>
<GoogleAnalytics />

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login - Fertel</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      color: #fff;
    }

    .login-container {
      width: 100%;
      max-width: 400px;
      padding: 2rem;
    }

    .login-box {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      padding: 2.5rem;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }

    .logo {
      text-align: center;
      margin-bottom: 2rem;
    }

    .logo h1 {
      font-size: 2rem;
      background: linear-gradient(135deg, #00d4ff 0%, #0099ff 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 0.5rem;
    }

    .logo p {
      color: #888;
      font-size: 0.9rem;
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    label {
      display: block;
      margin-bottom: 0.5rem;
      font-size: 0.9rem;
      color: #ccc;
      font-weight: 500;
    }

    input {
      width: 100%;
      padding: 0.75rem;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 6px;
      color: #fff;
      font-size: 1rem;
      transition: all 0.3s ease;
    }

    input:focus {
      outline: none;
      background: rgba(255, 255, 255, 0.12);
      border-color: rgba(0, 212, 255, 0.5);
      box-shadow: 0 0 10px rgba(0, 212, 255, 0.2);
    }

    input::placeholder {
      color: #666;
    }

    .login-btn {
      width: 100%;
      padding: 0.75rem;
      background: linear-gradient(135deg, #00d4ff 0%, #0099ff 100%);
      border: none;
      border-radius: 6px;
      color: #fff;
      font-weight: 600;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.3s ease;
      margin-top: 1rem;
    }

    .login-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(0, 212, 255, 0.3);
    }

    .login-btn:active {
      transform: translateY(0);
    }

    .error {
      background: rgba(255, 59, 48, 0.1);
      border: 1px solid rgba(255, 59, 48, 0.3);
      color: #ff6b6b;
      padding: 0.75rem;
      border-radius: 6px;
      margin-bottom: 1rem;
      display: none;
      font-size: 0.9rem;
    }

    .error.show {
      display: block;
    }

    .success {
      background: rgba(76, 175, 80, 0.1);
      border: 1px solid rgba(76, 175, 80, 0.3);
      color: #4caf50;
      padding: 0.75rem;
      border-radius: 6px;
      margin-bottom: 1rem;
      display: none;
      font-size: 0.9rem;
    }

    .success.show {
      display: block;
    }

    .loading {
      display: none;
      text-align: center;
      color: #00d4ff;
    }

    .spinner {
      display: inline-block;
      width: 20px;
      height: 20px;
      border: 3px solid rgba(0, 212, 255, 0.3);
      border-top-color: #00d4ff;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .info {
      background: rgba(33, 150, 243, 0.1);
      border: 1px solid rgba(33, 150, 243, 0.3);
      color: #64b5f6;
      padding: 0.75rem;
      border-radius: 6px;
      margin-bottom: 1rem;
      font-size: 0.85rem;
      line-height: 1.4;
    }

    .footer {
      text-align: center;
      margin-top: 2rem;
      color: #666;
      font-size: 0.85rem;
    }

    .footer a {
      color: #00d4ff;
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .footer a:hover {
      color: #0099ff;
    }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="login-box">
      <div class="logo">
        <h1>🔐 FERTEL</h1>
        <p>Admin Dashboard</p>
      </div>

      <div class="info">
        💡 Use seu token de admin para acessar o painel de controle de versões
      </div>

      <form id="loginForm">
        <div class="error" id="errorMsg"></div>
        <div class="success" id="successMsg"></div>

        <div class="form-group">
          <label for="token">Token de Admin</label>
          <input 
            type="password" 
            id="token" 
            name="token" 
            placeholder="sk_live_..." 
            required
            autocomplete="off"
          >
        </div>

        <button type="submit" class="login-btn" id="loginBtn">
          <span id="btnText">Entrar</span>
          <div class="loading" id="loading">
            <div class="spinner"></div>
          </div>
        </button>
      </form>

      <div class="footer">
        <p>Fertel Admin Panel © 2026</p>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('loginForm');
    const tokenInput = document.getElementById('token');
    const errorMsg = document.getElementById('errorMsg');
    const successMsg = document.getElementById('successMsg');
    const loginBtn = document.getElementById('loginBtn');
    const btnText = document.getElementById('btnText');
    const loading = document.getElementById('loading');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const token = tokenInput.value.trim();
      
      if (!token) {
        showError('Por favor, insira seu token');
        return;
      }

      // Mostrar loading
      loginBtn.disabled = true;
      btnText.style.display = 'none';
      loading.style.display = 'block';
      errorMsg.classList.remove('show');
      successMsg.classList.remove('show');

      try {
        // Testar token fazendo uma requisição à API
        const response = await fetch('/api/version-control?type=dll', {
          method: 'GET',
          headers: {
            'Authorization': `Bearer ${token}`
          }
        });

        if (response.ok) {
          // Token válido - salvar no localStorage e cookie
          localStorage.setItem('admin_token', token);
          document.cookie = `admin_token=${token}; path=/; max-age=86400`; // 24 horas
          
          showSuccess('Login bem-sucedido! Redirecionando...');
          
          setTimeout(() => {
            window.location.href = '/admin/versions';
          }, 1000);
        } else if (response.status === 401) {
          showError('Token inválido. Verifique e tente novamente.');
        } else {
          showError('Erro ao validar token. Tente novamente.');
        }
      } catch (error) {
        showError('Erro de conexão. Verifique sua internet.');
        console.error('Login error:', error);
      } finally {
        // Esconder loading
        loginBtn.disabled = false;
        btnText.style.display = 'inline';
        loading.style.display = 'none';
      }
    });

    function showError(message) {
      errorMsg.textContent = message;
      errorMsg.classList.add('show');
    }

    function showSuccess(message) {
      successMsg.textContent = message;
      successMsg.classList.add('show');
    }

    // Mostrar/esconder token
    const toggleBtn = document.createElement('button');
    toggleBtn.type = 'button';
    toggleBtn.style.cssText = `
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: #00d4ff;
      cursor: pointer;
      font-size: 1.2rem;
    `;
    toggleBtn.textContent = '👁️';
    
    const tokenGroup = document.querySelector('.form-group');
    tokenGroup.style.position = 'relative';
    
    tokenInput.addEventListener('focus', () => {
      tokenGroup.appendChild(toggleBtn);
    });

    toggleBtn.addEventListener('click', (e) => {
      e.preventDefault();
      if (tokenInput.type === 'password') {
        tokenInput.type = 'text';
        toggleBtn.textContent = '🙈';
      } else {
        tokenInput.type = 'password';
        toggleBtn.textContent = '👁️';
      }
    });
  </script>
</body>
</html>
