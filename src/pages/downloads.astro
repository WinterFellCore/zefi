---
import Sidebar from '../components/Sidebar.astro';
import UserProfileModal from '../components/UserProfileModal.astro';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Downloads - ZEFI</title>
  <style>
    :root {
      --theme-primary: #42467e;
      --theme-primary-hover: #5458a0;
      --theme-on-primary: #fff;
      --theme-bg: #1b191d;
      --theme-on-bg: #b0afb0;
      --theme-surface-1: #1f1d21;
      --theme-on-surface-1: #b0afb0;
      --theme-surface-2: #232127;
      --theme-on-surface-2: #b0afb0;
      --theme-text-secondary: #454349;
      --theme-border-color: #222224;
      --sidebar-width: 80px;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      height: 100%;
      width: 100%;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
    }

    body {
      background: var(--theme-bg);
      color: var(--theme-on-bg);
      display: flex;
    }

    /* Main Content */
    .main-content {
      margin-left: var(--sidebar-width);
      flex: 1;
      min-height: 100vh;
      overflow-y: auto;
    }

    .downloads-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 3rem 2rem;
    }

    .downloads-header {
      margin-bottom: 3rem;
      text-align: center;
    }

    .downloads-header h1 {
      font-size: 3rem;
      margin-bottom: 1rem;
      background: linear-gradient(135deg, #fff 0%, var(--theme-primary) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .downloads-header p {
      color: var(--theme-text-secondary);
      font-size: 1.15rem;
      max-width: 600px;
      margin: 0 auto;
    }

    .downloads-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }

    .download-card {
      background: var(--theme-surface-1);
      border: 1px solid var(--theme-border-color);
      border-radius: 20px;
      padding: 0;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      position: relative;
    }

    .download-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--theme-primary) 0%, #5458a0 100%);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .download-card:hover {
      border-color: var(--theme-primary);
      box-shadow: 0 24px 72px rgba(66, 70, 126, 0.3);
      transform: translateY(-8px);
    }

    .download-card:hover::before {
      opacity: 1;
    }

    .download-content {
      padding: 2rem;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .download-icon {
      width: 64px;
      height: 64px;
      background: linear-gradient(135deg, rgba(66, 70, 126, 0.2) 0%, rgba(84, 88, 160, 0.1) 100%);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.5rem;
      color: var(--theme-primary);
      transition: all 0.3s ease;
    }

    .download-card:hover .download-icon {
      transform: scale(1.1) rotate(5deg);
      background: linear-gradient(135deg, rgba(66, 70, 126, 0.3) 0%, rgba(84, 88, 160, 0.2) 100%);
    }

    .download-icon svg {
      width: 32px;
      height: 32px;
    }

    .download-card h3 {
      margin: 0 0 1rem 0;
      color: var(--theme-on-surface-1);
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: -0.01em;
    }

    .download-card p {
      margin: 0 0 1.5rem 0;
      color: var(--theme-text-secondary);
      font-size: 0.95rem;
      line-height: 1.7;
      flex: 1;
    }

    .download-meta {
      display: flex;
      gap: 1.25rem;
      margin-bottom: 1.5rem;
      padding: 1rem;
      background: var(--theme-surface-2);
      border-radius: 12px;
      border: 1px solid var(--theme-border-color);
    }

    .download-version,
    .download-size {
      font-size: 0.85rem;
      color: var(--theme-text-secondary);
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 500;
    }

    .download-version {
      color: var(--theme-primary);
      font-weight: 600;
    }

    .download-button {
      width: 100%;
      padding: 1.125rem;
      background: linear-gradient(135deg, var(--theme-primary) 0%, #5458a0 100%);
      color: var(--theme-on-primary);
      border: none;
      border-radius: 12px;
      font-size: 1.05rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      text-decoration: none;
      box-shadow: 0 4px 20px rgba(66, 70, 126, 0.4);
      position: relative;
      overflow: hidden;
    }

    .download-button::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
      transition: left 0.5s ease;
    }

    .download-button:hover::before {
      left: 100%;
    }

    .download-button:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(66, 70, 126, 0.5);
    }

    .download-button:active {
      transform: translateY(0);
    }

    .empty-state {
      text-align: center;
      padding: 4rem 2rem;
      color: var(--theme-text-secondary);
    }

    .empty-state-icon {
      width: 80px;
      height: 80px;
      margin: 0 auto 1.5rem;
      background: var(--theme-surface-2);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--theme-text-secondary);
    }

    .empty-state-icon svg {
      width: 40px;
      height: 40px;
    }

    .empty-state h3 {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
      color: var(--theme-on-surface-1);
    }

    .empty-state p {
      font-size: 1rem;
      color: var(--theme-text-secondary);
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    @media (max-width: 1200px) {
      .downloads-grid {
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      }
    }

    @media (max-width: 768px) {
      .main-content {
        margin-left: 60px;
      }

      .downloads-container {
        padding: 2rem 1rem;
      }

      .downloads-header h1 {
        font-size: 2rem;
      }

      .downloads-header p {
        font-size: 1rem;
      }

      .downloads-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }

      .download-content {
        padding: 1.5rem;
      }
    }
  </style>
</head>
<body>
  <Sidebar />
  <UserProfileModal />

  <!-- Main Content -->
  <div class="main-content">
    <div class="downloads-container">
      <div class="downloads-header">
        <h1>Downloads</h1>
        <p>Acesse seus arquivos e ferramentas disponíveis para download</p>
      </div>

      <div class="downloads-grid" id="downloadsGrid">
        <!-- Downloads serão carregados aqui -->
      </div>
    </div>
  </div>

  <script>
    // Verificar autenticação
    const authToken = localStorage.getItem('auth_token');
    const userData = localStorage.getItem('user_data');

    if (!authToken || !userData) {
      window.location.href = '/login';
    }

    // Carregar downloads
    async function loadDownloads() {
      const downloadsGrid = document.getElementById('downloadsGrid');
      if (!downloadsGrid) return;

      // Loading state
      downloadsGrid.innerHTML = `
        <div style="grid-column: 1 / -1; text-align: center; padding: 3rem; color: var(--theme-text-secondary);">
          <div style="width: 48px; height: 48px; border: 3px solid var(--theme-surface-2); border-top-color: var(--theme-primary); border-radius: 50%; margin: 0 auto 1rem; animation: spin 1s linear infinite;"></div>
          <p>Carregando downloads...</p>
        </div>
      `;

      try {
        const response = await fetch(`/api/downloads?t=${Date.now()}`, {
          headers: {
            'Authorization': `Bearer ${authToken}`
          }
        });

        const data = await response.json();

        if (data.success && data.downloads && data.downloads.length > 0) {
          downloadsGrid.innerHTML = data.downloads.map(download => `
            <div class="download-card">
              <div class="download-content">
                <div class="download-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
                  </svg>
                </div>
                <h3>${download.name}</h3>
                <p>${download.description}</p>
                ${(download.version || download.size) ? `
                  <div class="download-meta">
                    ${download.version ? `<div class="download-version">📦 ${download.version}</div>` : ''}
                    ${download.size ? `<div class="download-size">💾 ${download.size}</div>` : ''}
                  </div>
                ` : ''}
                <a href="${download.url}" class="download-button" target="_blank" rel="noopener noreferrer">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                  </svg>
                  Download
                </a>
              </div>
            </div>
          `).join('');
        } else {
          downloadsGrid.innerHTML = `
            <div class="empty-state" style="grid-column: 1 / -1;">
              <div class="empty-state-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                </svg>
              </div>
              <h3>Nenhum download disponível</h3>
              <p>Não há arquivos disponíveis para download no momento.</p>
            </div>
          `;
        }
      } catch (error) {
        console.error('Error loading downloads:', error);
        downloadsGrid.innerHTML = `
          <div class="empty-state" style="grid-column: 1 / -1;">
            <div class="empty-state-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3>Erro ao carregar downloads</h3>
            <p>Não foi possível carregar os downloads. Tente novamente mais tarde.</p>
          </div>
        `;
      }
    }

    loadDownloads();
  </script>
</body>
</html>
