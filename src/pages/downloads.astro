---
import Sidebar from '../components/Sidebar.astro';
import UserProfileModal from '../components/UserProfileModal.astro';
import PreviewModal from '../components/PreviewModal.astro';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Downloads - ZEFI</title>
  <style>
    :root {
      --theme-primary: #42467e;
      --theme-primary-hover: #5458a0;
      --theme-on-primary: #fff;
      --theme-bg: #1b191d;
      --theme-on-bg: #b0afb0;
      --theme-surface-1: #1f1d21;
      --theme-on-surface-1: #b0afb0;
      --theme-surface-2: #232127;
      --theme-on-surface-2: #b0afb0;
      --theme-text-secondary: #454349;
      --theme-border-color: #222224;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
      background: var(--theme-bg);
      color: var(--theme-on-bg);
      margin-left: 80px;
    }

    /* Main Content */
    .main-content {
      width: 100%;
      min-height: 100vh;
      padding: 3rem 2rem;
    }

    .downloads-container {
      max-width: 1400px;
      margin: 0 auto;
    }

    .downloads-header {
      margin-bottom: 3rem;
      text-align: center;
    }

    .downloads-header h1 {
      font-size: 3rem;
      margin-bottom: 1rem;
      background: linear-gradient(135deg, #fff 0%, var(--theme-primary) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .downloads-header p {
      color: var(--theme-text-secondary);
      font-size: 1.15rem;
    }

    /* Glass UI Card */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }

    .card {
      background: rgba(31, 29, 33, 0.6);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(66, 70, 126, 0.3);
      border-radius: 20px;
      padding: 2rem;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, transparent, var(--theme-primary), transparent);
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .card:hover {
      background: rgba(31, 29, 33, 0.8);
      border-color: var(--theme-primary);
      transform: translateY(-10px);
      box-shadow: 0 25px 70px rgba(66, 70, 126, 0.4);
    }

    .card:hover::before {
      opacity: 1;
    }

    .name {
      font-size: 1.75rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 0.75rem;
    }

    .desc {
      font-size: 1rem;
      color: var(--theme-text-secondary);
      margin-bottom: 1.5rem;
      line-height: 1.6;
    }

    .info {
      font-size: 0.9rem;
      color: var(--theme-primary);
      font-weight: 600;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .btn {
      display: block;
      width: 100%;
      padding: 1rem;
      background: linear-gradient(135deg, var(--theme-primary), #5458a0);
      color: #fff;
      text-align: center;
      text-decoration: none;
      border-radius: 12px;
      font-weight: 700;
      font-size: 1rem;
      transition: all 0.3s ease;
      box-shadow: 0 4px 20px rgba(66, 70, 126, 0.4);
      position: relative;
      overflow: hidden;
    }

    .btn::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
      transition: left 0.6s ease;
    }

    .btn:hover::before {
      left: 100%;
    }

    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(66, 70, 126, 0.6);
    }

    .empty-state {
      text-align: center;
      padding: 4rem 2rem;
      color: var(--theme-text-secondary);
    }

    .empty-state h3 {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
      color: var(--theme-on-surface-1);
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    @media (max-width: 768px) {
      body {
        margin-left: 60px;
      }

      .main-content {
        padding: 2rem 1rem;
      }

      .downloads-header h1 {
        font-size: 2rem;
      }

      .grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
    }
  </style>
</head>
<body>
  <Sidebar />
  <UserProfileModal />
  <PreviewModal />

  <!-- Main Content -->
  <div class="main-content">
    <div class="downloads-container">
      <div class="downloads-header">
        <h1>Downloads</h1>
        <p>Acesse seus arquivos e ferramentas disponíveis para download</p>
      </div>

      <div class="grid" id="downloadsGrid">
        <!-- Downloads serão carregados aqui -->
      </div>
    </div>
  </div>

  <script>
    // Verificar autenticação
    const authToken = localStorage.getItem('auth_token');
    const userData = localStorage.getItem('user_data');

    if (!authToken || !userData) {
      window.location.href = '/login';
    }

    // Carregar downloads
    async function loadDownloads() {
      const downloadsGrid = document.getElementById('downloadsGrid');
      if (!downloadsGrid) return;

      // Loading state
      downloadsGrid.innerHTML = `
        <div style="grid-column: 1 / -1; text-align: center; padding: 3rem; color: var(--theme-text-secondary);">
          <div style="width: 48px; height: 48px; border: 3px solid var(--theme-surface-2); border-top-color: var(--theme-primary); border-radius: 50%; margin: 0 auto 1rem; animation: spin 1s linear infinite;"></div>
          <p>Carregando downloads...</p>
        </div>
      `;

      try {
        const response = await fetch(`/api/downloads?t=${Date.now()}`, {
          headers: {
            'Authorization': `Bearer ${authToken}`
          }
        });

        const data = await response.json();

        if (data.success && data.downloads && data.downloads.length > 0) {
          downloadsGrid.innerHTML = data.downloads.map(download => `
            <div class="card glass">
              <div class="name">${download.name}</div>
              <div class="desc">${download.description}</div>
              <div class="info">${download.size || 'N/A'}</div>
              <a href="${download.url}" class="btn" target="_blank" rel="noopener noreferrer">Download</a>
            </div>
          `).join('');
        } else {
          downloadsGrid.innerHTML = `
            <div class="empty-state" style="grid-column: 1 / -1;">
              <h3>Nenhum download disponível</h3>
              <p>Não há arquivos disponíveis para download no momento.</p>
            </div>
          `;
        }
      } catch (error) {
        console.error('Error loading downloads:', error);
        downloadsGrid.innerHTML = `
          <div class="empty-state" style="grid-column: 1 / -1;">
            <h3>Erro ao carregar downloads</h3>
            <p>Não foi possível carregar os downloads. Tente novamente mais tarde.</p>
          </div>
        `;
      }
    }

    loadDownloads();
  </script>
</body>
</html>
