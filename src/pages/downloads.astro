---
import Sidebar from '../components/Sidebar.astro';
import UserProfileModal from '../components/UserProfileModal.astro';
import PreviewModal from '../components/PreviewModal.astro';
import Layout from '../layouts/Page.astro';
import { Container } from '@components/odyssey-theme';
---

<Sidebar />
<UserProfileModal />
<PreviewModal />

<Layout>
  <Container>
    <section class="downloads-section">
      <div class="downloads-header">
        <h1>Downloads</h1>
        <p>Acesse seus arquivos e ferramentas disponíveis para download</p>
      </div>

      <div class="downloads-grid" id="downloadsGrid">
        <!-- Downloads serão carregados aqui -->
      </div>
    </section>
  </Container>
</Layout>

<style>
  .downloads-section {
    padding: 5rem 0;
    min-height: 80vh;
  }

  .downloads-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .downloads-header h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #fff 0%, var(--theme-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 800;
  }

  .downloads-header p {
    color: var(--theme-text-secondary, #777);
    font-size: 1.1rem;
  }

  .downloads-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  /* Glass Card */
  .download-card {
    background: rgba(31, 29, 33, 0.5);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(66, 70, 126, 0.3);
    border-radius: 20px;
    padding: 2rem;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .download-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--theme-primary), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .download-card:hover {
    background: rgba(31, 29, 33, 0.7);
    border-color: var(--theme-primary);
    transform: translateY(-8px);
    box-shadow: 0 20px 60px rgba(66, 70, 126, 0.4);
  }

  .download-card:hover::before {
    opacity: 1;
  }

  .download-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
  }

  .download-subtitle {
    font-size: 0.875rem;
    color: var(--theme-text-secondary, #888);
    margin: 0;
  }

  .download-desc {
    font-size: 0.95rem;
    color: var(--theme-text-secondary, #aaa);
    line-height: 1.6;
    flex: 1;
  }

  .download-info {
    font-size: 0.875rem;
    color: var(--theme-primary);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .download-btn {
    display: block;
    width: 100%;
    padding: 1rem;
    background: linear-gradient(135deg, var(--theme-primary), #5458a0);
    color: #fff;
    text-align: center;
    text-decoration: none;
    border-radius: 12px;
    font-weight: 700;
    font-size: 1rem;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(66, 70, 126, 0.4);
    position: relative;
    overflow: hidden;
  }

  .download-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    transition: left 0.6s ease;
  }

  .download-btn:hover::before {
    left: 100%;
  }

  .download-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(66, 70, 126, 0.6);
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 4rem 2rem;
    color: var(--theme-text-secondary, #777);
  }

  .empty-state h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--theme-on-bg);
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 768px) {
    .downloads-section {
      padding: 3rem 0;
    }

    .downloads-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>

<script>
  // Verificar autenticação
  const authToken = localStorage.getItem('auth_token');
  const userData = localStorage.getItem('user_data');

  if (!authToken || !userData) {
    window.location.href = '/login';
  }

  // Carregar downloads
  async function loadDownloads() {
    const downloadsGrid = document.getElementById('downloadsGrid');
    if (!downloadsGrid) return;

    // Loading state
    downloadsGrid.innerHTML = `
      <div style="grid-column: 1 / -1; text-align: center; padding: 3rem; color: var(--theme-text-secondary);">
        <div style="width: 48px; height: 48px; border: 3px solid rgba(66, 70, 126, 0.2); border-top-color: var(--theme-primary); border-radius: 50%; margin: 0 auto 1rem; animation: spin 1s linear infinite;"></div>
        <p>Carregando downloads...</p>
      </div>
    `;

    try {
      const response = await fetch(`/api/downloads?t=${Date.now()}`, {
        headers: {
          'Authorization': `Bearer ${authToken}`
        }
      });

      const data = await response.json();

      if (data.success && data.downloads && data.downloads.length > 0) {
        downloadsGrid.innerHTML = data.downloads.map(download => `
          <div class="download-card">
            <div class="download-title">${download.name}</div>
            <div class="download-subtitle">Emuladores / Intel</div>
            <div class="download-desc">${download.description}</div>
            <div class="download-info">
              <span>${download.size || 'N/A'}</span>
              ${download.version ? `<span>• ${download.version}</span>` : ''}
            </div>
            <a href="${download.url}" class="download-btn" target="_blank" rel="noopener noreferrer">Download</a>
          </div>
        `).join('');
      } else {
        downloadsGrid.innerHTML = `
          <div class="empty-state">
            <h3>Nenhum download disponível</h3>
            <p>Não há arquivos disponíveis para download no momento.</p>
          </div>
        `;
      }
    } catch (error) {
      console.error('Error loading downloads:', error);
      downloadsGrid.innerHTML = `
        <div class="empty-state">
          <h3>Erro ao carregar downloads</h3>
          <p>Não foi possível carregar os downloads. Tente novamente mais tarde.</p>
        </div>
      `;
    }
  }

  loadDownloads();
</script>
