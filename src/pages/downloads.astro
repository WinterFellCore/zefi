<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Downloads - ZEFI</title>
  <style>
    :root {
      --theme-primary: #42467e;
      --theme-primary-hover: #5458a0;
      --theme-on-primary: #fff;
      --theme-bg: #1b191d;
      --theme-on-bg: #b0afb0;
      --theme-surface-1: #1f1d21;
      --theme-on-surface-1: #b0afb0;
      --theme-surface-2: #232127;
      --theme-on-surface-2: #b0afb0;
      --theme-text-secondary: #454349;
      --theme-border-color: #222224;
    }
  </style>
</head>
<body>
  <div class="downloads-wrapper">
    <div class="downloads-container">
      <div class="user-profile" id="userProfile" style="display: none;">
        <div class="profile-avatar" id="profileAvatar"></div>
        <div class="profile-info">
          <h2 id="profileName">Carregando...</h2>
          <p id="profileExpiry">Verificando acesso...</p>
        </div>
        <button class="logout-button" id="logoutButton">Sair</button>
      </div>

      <div class="downloads-header">
        <h1>Downloads</h1>
        <p>Seus arquivos disponíveis para download</p>
      </div>

      <div class="downloads-grid" id="downloadsGrid">
        <!-- Downloads serão carregados aqui -->
      </div>

      <div class="no-access" id="noAccess" style="display: none;">
        <div class="no-access-icon">🔒</div>
        <h2>Acesso Negado</h2>
        <p>Você não tem permissão para acessar esta área.</p>
        <a href="/login" class="back-button">Voltar ao Login</a>
      </div>
    </div>
  </div>
</body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html, body {
    height: 100%;
    width: 100%;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
  }

  body {
    background: var(--theme-bg);
    color: var(--theme-on-bg);
  }

  .downloads-wrapper {
    min-height: 100vh;
    width: 100%;
    background: var(--theme-bg);
    overflow-y: auto;
  }

  .downloads-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .user-profile {
    background: var(--theme-surface-1);
    border: 1px solid var(--theme-border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .profile-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--theme-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--theme-on-primary);
    flex-shrink: 0;
    overflow: hidden;
  }

  .profile-avatar img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
  }

  .profile-info {
    flex: 1;
  }

  .profile-info h2 {
    margin: 0 0 0.25rem 0;
    color: var(--theme-on-surface-1);
    font-size: 1.25rem;
  }

  .profile-info p {
    margin: 0;
    color: var(--theme-text-secondary);
    font-size: 0.9rem;
  }

  .logout-button {
    padding: 0.5rem 1.25rem;
    background: transparent;
    border: 1px solid var(--theme-border-color);
    border-radius: 6px;
    color: var(--theme-on-surface-1);
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 0.9rem;
  }

  .logout-button:hover {
    background: var(--theme-surface-2);
    border-color: var(--theme-primary);
  }

  .downloads-header {
    margin-bottom: 2rem;
  }

  .downloads-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--theme-on-bg);
  }

  .downloads-header p {
    color: var(--theme-text-secondary);
    font-size: 1.1rem;
  }

  .downloads-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  .download-card {
    background: var(--theme-surface-1);
    border: 1px solid var(--theme-border-color);
    border-radius: 16px;
    padding: 0;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
  }

  .download-card:hover {
    border-color: var(--theme-primary);
    box-shadow: 0 20px 60px rgba(66, 70, 126, 0.25);
    transform: translateY(-4px);
  }

  .download-image {
    width: 100%;
    height: 220px;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, var(--theme-surface-2) 0%, var(--theme-surface-1) 100%);
  }

  .download-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .download-card:hover .download-image img {
    transform: scale(1.05);
  }

  .download-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: linear-gradient(135deg, #ff6b1a 0%, #ff5500 100%);
    color: white;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 12px rgba(255, 107, 26, 0.4);
  }

  .download-content {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .download-icon {
    width: 48px;
    height: 48px;
    background: rgba(66, 70, 126, 0.15);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    color: var(--theme-primary);
  }

  .download-icon svg {
    width: 24px;
    height: 24px;
  }

  .download-card h3 {
    margin: 0 0 0.75rem 0;
    color: var(--theme-on-surface-1);
    font-size: 1.35rem;
    font-weight: 700;
  }

  .download-card p {
    margin: 0 0 1.25rem 0;
    color: var(--theme-text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    flex: 1;
  }

  .download-meta {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--theme-border-color);
  }

  .download-version,
  .download-size {
    font-size: 0.8rem;
    color: var(--theme-text-secondary);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .download-version::before {
    content: "📦";
    font-size: 1rem;
  }

  .download-size::before {
    content: "💾";
    font-size: 1rem;
  }

  .download-version {
    color: var(--theme-primary);
    font-weight: 600;
  }

  .download-button {
    width: 100%;
    padding: 1rem;
    background: linear-gradient(135deg, var(--theme-primary) 0%, #5458a0 100%);
    color: var(--theme-on-primary);
    border: none;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(66, 70, 126, 0.3);
    position: relative;
    overflow: hidden;
  }

  .download-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: left 0.5s ease;
  }

  .download-button:hover::before {
    left: 100%;
  }

  .download-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(66, 70, 126, 0.4);
  }

  .download-button svg {
    transition: transform 0.3s ease;
  }

  .download-button:hover svg {
    transform: translateY(2px);
  }

  .no-access {
    text-align: center;
    padding: 4rem 2rem;
  }

  .no-access-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
  }

  .no-access h2 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    color: var(--theme-on-bg);
  }

  .no-access p {
    color: var(--theme-text-secondary);
    margin-bottom: 2rem;
    font-size: 1.1rem;
  }

  .back-button {
    display: inline-block;
    padding: 0.875rem 2rem;
    background: var(--theme-primary);
    color: var(--theme-on-primary);
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .back-button:hover {
    background: var(--theme-primary-hover);
    transform: translateY(-1px);
  }
</style>

<script>
  // Verificar autenticação
  const authToken = localStorage.getItem('auth_token');
  const userData = localStorage.getItem('user_data');

  if (!authToken || !userData) {
    window.location.href = '/login';
  }

  const user = JSON.parse(userData || '{}');
  const userProfile = document.getElementById('userProfile');
  const profileAvatar = document.getElementById('profileAvatar');
  const profileName = document.getElementById('profileName');
  const profileExpiry = document.getElementById('profileExpiry');
  const downloadsGrid = document.getElementById('downloadsGrid');
  const noAccess = document.getElementById('noAccess');
  const logoutButton = document.getElementById('logoutButton');

  // Mostrar perfil do usuário
  if (userProfile && profileAvatar && profileName && profileExpiry) {
    userProfile.style.display = 'flex';
    
    // Avatar
    if (user.avatar_url) {
      profileAvatar.innerHTML = `<img src="${user.avatar_url}" alt="Avatar" />`;
    } else {
      const initial = (user.global_name || user.username || user.discord_id || '?')[0].toUpperCase();
      profileAvatar.textContent = initial;
    }

    // Nome
    profileName.textContent = user.global_name || user.username || `User ${user.discord_id}`;

    // Expiração
    if (user.expires_at) {
      const expiryDate = new Date(user.expires_at);
      const now = new Date();
      const daysRemaining = Math.ceil((expiryDate.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
      
      if (daysRemaining < 0) {
        profileExpiry.textContent = 'Acesso expirado';
        profileExpiry.style.color = '#ef4444';
      } else if (daysRemaining >= 365) {
        profileExpiry.textContent = 'Acesso vitalício';
      } else if (daysRemaining >= 30) {
        profileExpiry.textContent = `Acesso válido por ${Math.floor(daysRemaining / 30)} meses`;
      } else {
        profileExpiry.textContent = `Acesso válido por ${daysRemaining} dias`;
      }
    } else {
      profileExpiry.textContent = 'Acesso vitalício';
    }
  }

  // Logout
  if (logoutButton) {
    logoutButton.addEventListener('click', () => {
      localStorage.removeItem('auth_token');
      localStorage.removeItem('user_data');
      localStorage.removeItem('discord_id');
      window.location.href = '/login';
    });
  }

  // Carregar downloads
  async function loadDownloads() {
    try {
      // Adiciona timestamp para evitar cache
      const response = await fetch(`/api/downloads?t=${Date.now()}`, {
        headers: {
          'Authorization': `Bearer ${authToken}`
        }
      });

      const data = await response.json();

      if (data.success && data.downloads && data.downloads.length > 0) {
        renderDownloads(data.downloads);
      } else {
        // Mostrar mensagem de sem acesso
        if (downloadsGrid) downloadsGrid.style.display = 'none';
        if (noAccess) noAccess.style.display = 'block';
      }
    } catch (error) {
      console.error('Error loading downloads:', error);
      // Mostrar mensagem de erro
      if (downloadsGrid) {
        downloadsGrid.innerHTML = '<p style="color: var(--theme-text-secondary); text-align: center; padding: 2rem;">Erro ao carregar downloads. Tente novamente mais tarde.</p>';
      }
    }
  }

  function renderDownloads(downloads: any[]) {
    if (!downloadsGrid) return;

    downloadsGrid.innerHTML = downloads.map(download => `
      <div class="download-card">
        ${download.image ? `
          <div class="download-image">
            <img src="${download.image}" alt="${download.name}" />
            ${download.name.includes('MAX') ? '<div class="download-badge">MAX</div>' : ''}
          </div>
        ` : `
          <div class="download-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
            </svg>
          </div>
        `}
        <div class="download-content">
          <h3>${download.name}</h3>
          <p>${download.description}</p>
          ${(download.version || download.size) ? `
            <div class="download-meta">
              ${download.version ? `<div class="download-version">${download.version}</div>` : ''}
              ${download.size ? `<div class="download-size">${download.size}</div>` : ''}
            </div>
          ` : ''}
          <a href="${download.url}" class="download-button" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            Download
          </a>
        </div>
      </div>
    `).join('');
  }

  // Carregar downloads ao iniciar
  loadDownloads();
</script>

