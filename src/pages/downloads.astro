---
import Sidebar from '../components/Sidebar.astro';
import UserProfileModal from '../components/UserProfileModal.astro';
import PreviewModal from '../components/PreviewModal.astro';
import Layout from '../layouts/Page.astro';
import { Container } from '@components/odyssey-theme';
---

<Sidebar />
<UserProfileModal />
<PreviewModal />

<Layout>
  <Container>
    <section class="downloads-section">
      <div class="downloads-header">
        <h1>Downloads</h1>
        <p>Acesse seus arquivos e ferramentas disponíveis para download</p>
      </div>

      <div class="downloads-grid" id="downloadsGrid">
        <!-- Downloads serão carregados aqui -->
      </div>
    </section>
  </Container>
</Layout>

<style is:global>
  .downloads-section {
    padding: 5rem 0;
    min-height: 80vh;
  }

  .downloads-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .downloads-header h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #fff 0%, var(--theme-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 800;
  }

  .downloads-header p {
    color: var(--theme-text-secondary, #777);
    font-size: 1.1rem;
  }

  .downloads-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  /* Card padrão - Variação 1 */
  .download-card {
    background: #151a26 !important;
    border-radius: 14px !important;
    padding: 20px !important;
    transition: 0.3s !important;
  }

  .download-card:hover {
    transform: translateY(-5px) !important;
    box-shadow: 0 0 25px rgba(0, 0, 0, 0.6) !important;
  }

  .download-card .name {
    font-weight: bold !important;
    margin-bottom: 5px !important;
    font-size: 1.1rem !important;
    color: #fff !important;
  }

  .download-card .desc {
    font-size: 12px !important;
    color: #aaa !important;
    margin-bottom: 10px !important;
  }

  .download-card .info {
    font-size: 11px !important;
    color: #666 !important;
    margin-bottom: 15px !important;
  }

  .download-card .btn {
    display: inline-block !important;
    padding: 8px 14px !important;
    background: #4e7cff !important;
    border-radius: 6px !important;
    text-decoration: none !important;
    color: #fff !important;
    font-size: 12px !important;
    transition: all 0.2s ease !important;
  }

  .download-card .btn:hover {
    background: #6b93ff !important;
    transform: translateY(-2px) !important;
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 4rem 2rem;
    color: var(--theme-text-secondary, #777);
  }

  .empty-state h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--theme-on-bg);
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 768px) {
    .downloads-section {
      padding: 3rem 0;
    }

    .downloads-grid {
      grid-template-columns: 1fr;
      gap: 15px;
    }
  }
</style>

<script>
  // Verificar autenticação
  const authToken = localStorage.getItem('auth_token');
  const userData = localStorage.getItem('user_data');

  if (!authToken || !userData) {
    window.location.href = '/login';
  }

  // Carregar downloads
  async function loadDownloads() {
    const downloadsGrid = document.getElementById('downloadsGrid');
    if (!downloadsGrid) return;

    // Loading state
    downloadsGrid.innerHTML = `
      <div style="grid-column: 1 / -1; text-align: center; padding: 3rem; color: var(--theme-text-secondary);">
        <div style="width: 48px; height: 48px; border: 3px solid rgba(66, 70, 126, 0.2); border-top-color: var(--theme-primary); border-radius: 50%; margin: 0 auto 1rem; animation: spin 1s linear infinite;"></div>
        <p>Carregando downloads...</p>
      </div>
    `;

    try {
      const response = await fetch(`/api/downloads?t=${Date.now()}`, {
        headers: {
          'Authorization': `Bearer ${authToken}`
        }
      });

      const data = await response.json();

      if (data.success && data.downloads && data.downloads.length > 0) {
        downloadsGrid.innerHTML = data.downloads.map(download => `
          <div class="download-card">
            <div class="name">${download.name}</div>
            <div class="desc">Emuladores / Intel</div>
            <div class="info">${download.size || 'N/A'} • ${download.version || 'OB53'}</div>
            <a href="${download.url}" class="btn" target="_blank" rel="noopener noreferrer">Download</a>
          </div>
        `).join('');
      } else {
        downloadsGrid.innerHTML = `
          <div class="empty-state">
            <h3>Nenhum download disponível</h3>
            <p>Não há arquivos disponíveis para download no momento.</p>
          </div>
        `;
      }
    } catch (error) {
      console.error('Error loading downloads:', error);
      downloadsGrid.innerHTML = `
        <div class="empty-state">
          <h3>Erro ao carregar downloads</h3>
          <p>Não foi possível carregar os downloads. Tente novamente mais tarde.</p>
        </div>
      `;
    }
  }

  loadDownloads();
</script>
