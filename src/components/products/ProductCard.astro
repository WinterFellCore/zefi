---
export interface Props {
	name: string;
	description: string;
	features: string[];
	price: number;
	currency?: string;
	popular?: boolean;
	characterImage?: string;
}

const { name, description, features, price, currency = 'BRL', popular = false, characterImage } = Astro.props;

const formatPrice = (value: number, curr: string) => {
	return new Intl.NumberFormat('pt-BR', {
		style: 'currency',
		currency: curr
	}).format(value);
};
---

<div class="product-card" class:list={[{ popular }]}>

	<!-- Character image — topo direito -->
	{characterImage && (
		<div class="character-wrap" aria-hidden="true">
			<img src={characterImage} alt="" class="character-img" loading="lazy" />
		</div>
	)}

	<!-- Popular badge -->
	{popular && <div class="popular-badge">Mais Popular</div>}

	<div class="card-inner">
		<!-- Header: tag + título com espaço à direita para o personagem -->
		<div class="product-header">
			<p class="product-tag">{description}</p>
			<h3>{name}</h3>
		</div>

		<!-- Features -->
		<ul class="product-features">
			{features.map((feature) => (
				<li>
					<svg class="check-icon" width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
						<circle cx="7.5" cy="7.5" r="7" stroke="currentColor" stroke-opacity="0.25"/>
						<path d="M4.5 7.5l2.5 2.5 3.5-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
					{feature}
				</li>
			))}
		</ul>

		<!-- Footer: preço + botão -->
		<div class="product-footer">
			<div class="price-row">
				<span class="price">{formatPrice(price, currency)}</span>
				<span class="period">/mês</span>
			</div>
			<button class="buy-button">Comprar Agora</button>
		</div>
	</div>
</div>

<style>
	.product-card {
		background: var(--theme-surface-1);
		border: 1px solid var(--theme-border-color, #222);
		border-radius: 16px;
		position: relative;
		overflow: hidden;
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
		/* Altura mínima maior para acomodar o personagem no topo */
		min-height: 480px;
		display: flex;
		flex-direction: column;
	}

	.product-card:hover {
		border-color: #333;
		box-shadow: 0 12px 48px rgba(0, 0, 0, 0.5);
	}

	.product-card.popular {
		border-color: rgba(255, 77, 166, 0.4);
	}

	.product-card.popular:hover {
		border-color: rgba(255, 77, 166, 0.7);
		box-shadow: 0 12px 48px rgba(255, 77, 166, 0.12);
	}

	/* ── Personagem: topo direito ── */
	.character-wrap {
		position: absolute;
		top: 0;
		right: 0;
		width: 180px;
		height: 240px;
		pointer-events: none;
		z-index: 1;
		/* Fade nas bordas para integrar ao card */
		mask-image:
			linear-gradient(to bottom, transparent 0%, black 18%, black 75%, transparent 100%),
			linear-gradient(to left,   transparent 0%, black 20%);
		-webkit-mask-image:
			linear-gradient(to bottom, transparent 0%, black 18%, black 75%, transparent 100%),
			linear-gradient(to left,   transparent 0%, black 20%);
		mask-composite: intersect;
		-webkit-mask-composite: source-in;
	}

	.character-img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: top right;
		opacity: 0.82;
		transition: opacity 0.25s ease, transform 0.3s ease;
	}

	.product-card:hover .character-img {
		opacity: 0.95;
		transform: scale(1.04) translateY(4px);
	}

	/* ── Popular badge ── */
	.popular-badge {
		position: absolute;
		/* Fica abaixo do personagem, no canto direito */
		top: 1rem;
		right: 1rem;
		background: rgba(255, 77, 166, 0.12);
		border: 1px solid rgba(255, 77, 166, 0.35);
		color: var(--theme-primary);
		padding: 0.25rem 0.8rem;
		border-radius: 999px;
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.5px;
		font-family: var(--theme-font-family-sans);
		z-index: 2;
	}

	/* ── Conteúdo interno ── */
	.card-inner {
		position: relative;
		z-index: 2;
		padding: 1.75rem;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		flex: 1;
	}

	/* Header: reserva espaço à direita para o personagem não cobrir o título */
	.product-header {
		padding-right: 160px; /* largura do personagem */
		min-height: 80px;     /* garante espaço mesmo sem personagem */
	}

	.product-tag {
		font-size: 0.65rem;
		font-weight: 600;
		letter-spacing: 2.5px;
		text-transform: uppercase;
		color: var(--theme-text-secondary);
		margin: 0 0 0.4rem 0;
		font-family: var(--theme-font-family-sans);
	}

	.product-header h3 {
		font-size: clamp(1.6rem, 3vw, 2rem);
		margin: 0;
		color: var(--theme-on-bg);
		font-weight: 700;
		line-height: 1;
		letter-spacing: 0.5px;
		font-family: var(--theme-font-family-serif);
		text-transform: uppercase;
	}

	/* Features */
	.product-features {
		list-style: none;
		padding: 0;
		margin: 0;
		flex-grow: 1;
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
	}

	.product-features li {
		font-size: 0.83rem;
		color: var(--theme-text-secondary);
		line-height: 1.4;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-family: var(--theme-font-family-sans);
	}

	.check-icon {
		color: var(--theme-primary);
		flex-shrink: 0;
	}

	/* Footer */
	.product-footer {
		display: flex;
		flex-direction: column;
		gap: 0.875rem;
		padding-top: 1.25rem;
		border-top: 1px solid var(--theme-border-color, #222);
	}

	.price-row {
		display: flex;
		align-items: baseline;
		gap: 0.3rem;
	}

	.price {
		font-size: 2rem;
		font-weight: 700;
		color: var(--theme-on-bg);
		font-family: var(--theme-font-family-serif);
	}

	.period {
		font-size: 0.82rem;
		color: var(--theme-text-secondary);
		font-family: var(--theme-font-family-sans);
	}

	.buy-button {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		padding: 0.85rem 1.25rem;
		background: var(--theme-primary);
		color: white;
		border: none;
		border-radius: 8px;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 1px;
		text-transform: uppercase;
		cursor: pointer;
		transition: background 0.2s ease, transform 0.15s ease;
		font-family: var(--theme-font-family-sans);
	}

	.buy-button:hover {
		background: var(--theme-primary-hover);
		transform: translateY(-1px);
	}

	.buy-button:active {
		transform: scale(0.98);
	}

	/* ── Responsivo ── */
	@media (max-width: 768px) {
		.product-card {
			min-height: 420px;
		}

		.character-wrap {
			width: 140px;
			height: 190px;
		}

		.product-header {
			padding-right: 120px;
		}

		.card-inner {
			padding: 1.5rem;
		}

		.price {
			font-size: 1.7rem;
		}
	}
</style>
