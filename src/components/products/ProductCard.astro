---
export interface Props {
	name: string;
	description: string;
	features: string[];
	price: number;
	currency?: string;
	popular?: boolean;
	characterImage?: string;
}

const { name, description, features, price, currency = 'BRL', popular = false, characterImage } = Astro.props;

const formatPrice = (value: number, curr: string) => {
	return new Intl.NumberFormat('pt-BR', {
		style: 'currency',
		currency: curr
	}).format(value);
};
---

<div class="product-card" class:list={[{ popular }]}>

	<!-- Personagem: posicionado relativo ao card inteiro, vaza pra cima -->
	{characterImage && (
		<div class="character-wrap" aria-hidden="true">
			<img src={characterImage} alt="" class="character-img" loading="lazy" />
		</div>
	)}

	<!-- Conteúdo do card -->
	<div class="card-inner">
		<!-- Badge + tag no topo -->
		<div class="card-header">
			{popular && <div class="popular-badge">Mais Popular</div>}
			<p class="product-tag">{description}</p>
		</div>

		<h3 class="product-name">{name}</h3>

		<ul class="product-features">
			{features.map((feature) => (
				<li>
					<svg class="check-icon" width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
						<circle cx="7.5" cy="7.5" r="7" stroke="currentColor" stroke-opacity="0.25"/>
						<path d="M4.5 7.5l2.5 2.5 3.5-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
					{feature}
				</li>
			))}
		</ul>

		<div class="product-footer">
			<div class="price-row">
				<span class="price">{formatPrice(price, currency)}</span>
				<span class="period">/mês</span>
			</div>
			<a href="https://discord.gg/jsymg94sXB" target="_blank" rel="noopener noreferrer" class="buy-button">Ver no Discord</a>
		</div>
	</div>
</div>

<style>
	.product-card {
		background: var(--theme-surface-1);
		border: 1px solid var(--theme-border-color, #222);
		border-radius: 16px;
		overflow: visible;
		display: flex;
		flex-direction: column;
		position: relative;
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}

	.product-card:hover {
		border-color: #333;
		box-shadow: 0 12px 48px rgba(0, 0, 0, 0.5);
	}

	.product-card.popular {
		border-color: rgba(255, 77, 166, 0.45);
	}

	.product-card.popular:hover {
		border-color: rgba(255, 77, 166, 0.75);
		box-shadow: 0 12px 48px rgba(255, 77, 166, 0.13);
	}

	/* ── Personagem: relativo ao card, lado direito, vaza pra cima ── */
	.character-wrap {
		position: absolute;
		right: 10px;
		top: -220px;
		width: 260px;
		height: 340px;
		z-index: 0;
		pointer-events: none;
	}

	.character-img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: bottom right;
		opacity: 1;
		transition: transform 0.35s ease;
	}

	.product-card:hover .character-img {
		transform: scale(1.05) translateY(-8px);
	}

	/* ── Conteúdo ── */
	.card-inner {
		position: relative;
		z-index: 2;
		padding: 1.75rem;
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
		flex: 1;
	}

	.card-header {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		padding-right: 150px;
	}

	/* ── Popular badge ── */
	.popular-badge {
		display: inline-block;
		background: rgba(255, 77, 166, 0.12);
		border: 1px solid rgba(255, 77, 166, 0.35);
		color: var(--theme-primary);
		padding: 0.2rem 0.7rem;
		border-radius: 999px;
		font-size: 0.65rem;
		font-weight: 700;
		letter-spacing: 0.5px;
		font-family: var(--theme-font-family-sans);
		width: fit-content;
	}

	.product-tag {
		font-size: 0.65rem;
		font-weight: 600;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: var(--theme-text-secondary);
		margin: 0;
		font-family: var(--theme-font-family-sans);
	}

	.product-name {
		font-size: clamp(1.9rem, 3.5vw, 2.4rem);
		margin: 0;
		color: var(--theme-on-bg);
		font-weight: 700;
		line-height: 1;
		letter-spacing: 1px;
		font-family: var(--theme-font-family-serif);
		text-transform: uppercase;
		padding-right: 150px;
	}

	/* ── Features ── */
	.product-features {
		list-style: none;
		padding: 0;
		margin: 0;
		flex-grow: 1;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.product-features li {
		font-size: 0.83rem;
		color: var(--theme-text-secondary);
		line-height: 1.4;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-family: var(--theme-font-family-sans);
	}

	.check-icon {
		color: var(--theme-primary);
		flex-shrink: 0;
	}

	/* ── Footer ── */
	.product-footer {
		display: flex;
		flex-direction: column;
		gap: 0.875rem;
		padding-top: 1.25rem;
		border-top: 1px solid var(--theme-border-color, #222);
	}

	.price-row {
		display: flex;
		align-items: baseline;
		gap: 0.3rem;
	}

	.price {
		font-size: 2rem;
		font-weight: 700;
		color: var(--theme-on-bg);
		font-family: var(--theme-font-family-serif);
	}

	.period {
		font-size: 0.82rem;
		color: var(--theme-text-secondary);
		font-family: var(--theme-font-family-sans);
	}

	.buy-button {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		padding: 0.875rem;
		background: var(--theme-primary);
		color: white;
		border: none;
		border-radius: 8px;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 1px;
		text-transform: uppercase;
		text-decoration: none;
		cursor: pointer;
		transition: background 0.2s ease, transform 0.15s ease;
		font-family: var(--theme-font-family-sans);
	}

	.buy-button:hover {
		background: var(--theme-primary-hover);
		transform: translateY(-1px);
	}

	.buy-button:active {
		transform: scale(0.98);
	}

	/* ── Responsivo ── */
	@media (max-width: 768px) {
		.character-wrap {
			width: 220px;
			height: 280px;
			top: -120px;
		}

		.product-name {
			font-size: 1.7rem;
		}
	}
</style>
