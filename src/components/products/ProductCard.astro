---
export interface Props {
	name: string;
	description: string;
	features: string[];
	price: number;
	currency?: string;
	popular?: boolean;
	characterImage?: string;
}

const { name, description, features, price, currency = 'BRL', popular = false, characterImage } = Astro.props;

const formatPrice = (value: number, curr: string) => {
	return new Intl.NumberFormat('pt-BR', {
		style: 'currency',
		currency: curr
	}).format(value);
};
---

<div class="product-card" class:list={[{ popular }]}>
	{popular && <div class="popular-badge">Mais Popular</div>}

	<!-- Character image decorativa -->
	{characterImage && (
		<div class="character-wrap" aria-hidden="true">
			<img src={characterImage} alt="" class="character-img" loading="lazy" />
		</div>
	)}

	<div class="card-inner">
		<div class="product-header">
			<p class="product-tag">{description}</p>
			<h3>{name}</h3>
		</div>

		<ul class="product-features">
			{features.map((feature) => (
				<li>
					<svg class="check-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
						<circle cx="7" cy="7" r="6.5" stroke="currentColor" stroke-opacity="0.3"/>
						<path d="M4.5 7l2 2 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
					{feature}
				</li>
			))}
		</ul>

		<div class="product-footer">
			<div class="price-row">
				<span class="price">{formatPrice(price, currency)}</span>
				<span class="period">/mês</span>
			</div>
			<button class="buy-button">
				Comprar Agora
			</button>
		</div>
	</div>
</div>

<style>
	.product-card {
		background: var(--theme-surface-1);
		border: 1px solid var(--theme-border-color, #222);
		border-radius: 16px;
		display: flex;
		flex-direction: column;
		position: relative;
		overflow: hidden;
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
		min-height: 400px;
	}

	.product-card:hover {
		border-color: #333;
		box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
	}

	.product-card.popular {
		border-color: rgba(255, 77, 166, 0.4);
	}

	.product-card.popular:hover {
		border-color: rgba(255, 77, 166, 0.7);
		box-shadow: 0 8px 40px rgba(255, 77, 166, 0.1);
	}

	/* Character image */
	.character-wrap {
		position: absolute;
		bottom: 0;
		right: -8px;
		width: 150px;
		height: 210px;
		pointer-events: none;
		z-index: 1;
		mask-image: linear-gradient(to top, transparent 0%, black 25%, black 85%, transparent 100%);
		-webkit-mask-image: linear-gradient(to top, transparent 0%, black 25%, black 85%, transparent 100%);
	}

	.character-img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: bottom center;
		opacity: 0.75;
		transition: opacity 0.25s ease;
	}

	.product-card:hover .character-img {
		opacity: 0.9;
	}

	/* Card inner */
	.card-inner {
		position: relative;
		z-index: 2;
		padding: 1.75rem;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		flex: 1;
	}

	/* Popular badge */
	.popular-badge {
		position: absolute;
		top: 1rem;
		right: 1rem;
		background: rgba(255, 77, 166, 0.12);
		border: 1px solid rgba(255, 77, 166, 0.3);
		color: var(--theme-primary);
		padding: 0.25rem 0.75rem;
		border-radius: 999px;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.5px;
		font-family: var(--theme-font-family-sans);
		z-index: 3;
	}

	/* Header */
	.product-tag {
		font-size: 0.68rem;
		font-weight: 600;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: var(--theme-text-secondary);
		margin: 0 0 0.4rem 0;
		font-family: var(--theme-font-family-sans);
	}

	.product-header h3 {
		font-size: clamp(1.5rem, 3vw, 1.9rem);
		margin: 0;
		color: var(--theme-on-bg);
		font-weight: 700;
		line-height: 1;
		letter-spacing: 0.5px;
		font-family: var(--theme-font-family-serif);
		text-transform: uppercase;
	}

	/* Features */
	.product-features {
		list-style: none;
		padding: 0;
		margin: 0;
		flex-grow: 1;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.product-features li {
		font-size: 0.82rem;
		color: var(--theme-text-secondary, #aaa);
		line-height: 1.4;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-family: var(--theme-font-family-sans);
	}

	.check-icon {
		color: var(--theme-primary);
		flex-shrink: 0;
	}

	/* Footer */
	.product-footer {
		display: flex;
		flex-direction: column;
		gap: 0.875rem;
		padding-top: 1.25rem;
		border-top: 1px solid var(--theme-border-color, #222);
		margin-right: 110px;
	}

	.price-row {
		display: flex;
		align-items: baseline;
		gap: 0.3rem;
	}

	.price {
		font-size: 1.8rem;
		font-weight: 700;
		color: var(--theme-on-bg);
		font-family: var(--theme-font-family-serif);
	}

	.period {
		font-size: 0.82rem;
		color: var(--theme-text-secondary);
		font-family: var(--theme-font-family-sans);
	}

	.buy-button {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		padding: 0.75rem 1.25rem;
		background: var(--theme-primary);
		color: white;
		border: none;
		border-radius: 8px;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 1px;
		text-transform: uppercase;
		cursor: pointer;
		transition: background 0.2s ease, transform 0.15s ease;
		font-family: var(--theme-font-family-sans);
	}

	.buy-button:hover {
		background: var(--theme-primary-hover);
		transform: translateY(-1px);
	}

	.buy-button:active {
		transform: scale(0.98);
	}

	@media (max-width: 768px) {
		.character-wrap {
			width: 110px;
			height: 160px;
		}

		.product-footer {
			margin-right: 80px;
		}

		.card-inner {
			padding: 1.5rem;
		}
	}
</style>
