---
import { Container } from '@components/odyssey-theme';
---

<section class="zefi-hero">
	<Container>
		<div class="hero-content">

			<!-- Badge pill -->
			<div class="hero-badge">
				<span class="badge-dot" aria-hidden="true"></span>
				Free Fire • Roblox • Minecraft Java
			</div>

			<!-- Título principal -->
			<h1 class="hero-title">
				Performance<br />
				<span class="hero-title--accent">superior</span>
			</h1>

			<p class="hero-subtitle">
				Ferramentas avançadas para seus jogos favoritos.<br />
				Undetected. Stable. Updated.
			</p>

			<!-- CTA -->
			<div class="hero-cta">
				<a href="#produtos" class="cta-button cta-button--primary">
					Ver Produtos
				</a>
				<a href="#produtos" class="cta-button cta-button--ghost">
					Saiba mais
				</a>
			</div>

			<!-- Stats -->
			<div class="hero-stats">
				<div class="stat">
					<span class="stat-value">3</span>
					<span class="stat-label">Produtos</span>
				</div>
				<div class="stat-divider" aria-hidden="true"></div>
				<div class="stat">
					<span class="stat-value">24/7</span>
					<span class="stat-label">Suporte</span>
				</div>
				<div class="stat-divider" aria-hidden="true"></div>
				<div class="stat">
					<span class="stat-value">100%</span>
					<span class="stat-label">Undetected</span>
				</div>
			</div>

		</div>
	</Container>
</section>

<style>
	.zefi-hero {
		min-height: 80vh;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		background: var(--theme-bg);
		padding: 10rem 0 5rem;
		overflow: hidden;
	}

	/* Glow central sutil */
	.zefi-hero::before {
		content: '';
		position: absolute;
		top: 20%;
		left: 50%;
		transform: translateX(-50%);
		width: 600px;
		height: 400px;
		background: radial-gradient(ellipse, rgba(255, 107, 26, 0.07) 0%, transparent 70%);
		pointer-events: none;
	}

	.hero-content {
		position: relative;
		z-index: 1;
		text-align: center;
		max-width: 720px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
	}

	/* Badge pill */
	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		background: rgba(255, 107, 26, 0.08);
		border: 1px solid rgba(255, 107, 26, 0.2);
		color: var(--theme-primary);
		padding: 0.4rem 1rem;
		border-radius: 999px;
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.5px;
		font-family: var(--theme-font-family-sans);
	}

	.badge-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--theme-primary);
		animation: pulse 2s ease-in-out infinite;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.4; }
	}

	/* Título */
	.hero-title {
		font-size: clamp(3.2rem, 9vw, 6rem);
		font-weight: 700;
		color: var(--theme-on-bg);
		margin: 0;
		line-height: 1;
		letter-spacing: -0.5px;
		text-transform: uppercase;
		font-family: var(--theme-font-family-serif);
	}

	.hero-title--accent {
		background: linear-gradient(135deg, var(--theme-primary) 0%, #d94e00 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	/* Subtítulo */
	.hero-subtitle {
		font-size: clamp(0.9rem, 1.8vw, 1.05rem);
		color: var(--theme-text-secondary);
		margin: 0;
		line-height: 1.7;
		font-weight: 400;
		font-family: var(--theme-font-family-sans);
	}

	/* CTAs */
	.hero-cta {
		display: flex;
		gap: 0.75rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.cta-button {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.8rem 1.75rem;
		text-decoration: none;
		border-radius: 8px;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 1px;
		text-transform: uppercase;
		transition: all 0.2s ease;
		font-family: var(--theme-font-family-sans);
	}

	.cta-button--primary {
		background: var(--theme-primary);
		color: white;
	}

	.cta-button--primary:hover {
		background: var(--theme-primary-hover);
		transform: translateY(-1px);
		box-shadow: 0 6px 24px rgba(255, 107, 26, 0.3);
	}

	.cta-button--ghost {
		background: transparent;
		color: var(--theme-text-secondary);
		border: 1px solid var(--theme-border-color, #333);
	}

	.cta-button--ghost:hover {
		border-color: rgba(255, 255, 255, 0.3);
		color: var(--theme-on-bg);
	}

	/* Stats */
	.hero-stats {
		display: flex;
		align-items: center;
		gap: 2rem;
		margin-top: 0.5rem;
	}

	.stat {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.2rem;
	}

	.stat-value {
		font-size: 1.4rem;
		font-weight: 700;
		color: var(--theme-on-bg);
		font-family: var(--theme-font-family-serif);
		letter-spacing: 0.5px;
	}

	.stat-label {
		font-size: 0.7rem;
		font-weight: 500;
		color: var(--theme-text-secondary);
		letter-spacing: 1px;
		text-transform: uppercase;
		font-family: var(--theme-font-family-sans);
	}

	.stat-divider {
		width: 1px;
		height: 32px;
		background: var(--theme-border-color, #333);
	}

	@media (max-width: 768px) {
		.zefi-hero {
			min-height: 60vh;
			padding: 8rem 0 4rem;
		}

		.hero-title {
			font-size: clamp(2.8rem, 12vw, 4rem);
		}

		.hero-stats {
			gap: 1.25rem;
		}
	}
</style>
