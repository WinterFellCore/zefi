---
import { Container } from '@components/odyssey-theme';
---

<section class="zefi-hero">
	<Container>
		<div class="hero-content">
			<h1 class="hero-title fade">
				<span class="zefi-logo">ZEFI</span>
			</h1>
			<p class="hero-subtitle fade delay1">Performance sem limites.</p>
			<p class="hero-subtitle fade delay2">Controle total na sua mão.</p>
			<div class="hero-cta fade delay3">
				<a href="#produtos" class="cta-button">Ver Produtos</a>
			</div>
		</div>
	</Container>
</section>

<style>
	.zefi-hero {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		overflow: hidden;
		background: linear-gradient(135deg, #0f0f10 0%, #1a0a15 100%);
	}

	.zefi-hero::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: 
			radial-gradient(circle at 20% 50%, rgba(255, 77, 166, 0.1) 0%, transparent 50%),
			radial-gradient(circle at 80% 80%, rgba(255, 77, 166, 0.08) 0%, transparent 50%);
		pointer-events: none;
	}

	.hero-content {
		position: relative;
		z-index: 1;
		text-align: left;
		padding: 2rem 0;
	}

	.hero-title {
		margin: 0 0 2rem 0;
	}

	.zefi-logo {
		font-size: clamp(4rem, 15vw, 8rem);
		font-weight: 900;
		color: var(--theme-primary);
		letter-spacing: 0.05em;
		line-height: 1;
		display: block;
		text-transform: uppercase;
		background: linear-gradient(135deg, #ff4da6 0%, #ff2d95 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-subtitle {
		font-size: clamp(1.5rem, 4vw, 2.5rem);
		color: var(--theme-text-secondary, #aaa);
		margin: 0 0 1rem 0;
		line-height: 1.4;
		font-weight: 300;
	}

	.hero-cta {
		margin-top: 3rem;
	}

	.cta-button {
		display: inline-block;
		padding: 1rem 2.5rem;
		background: var(--theme-primary);
		color: white;
		text-decoration: none;
		border-radius: 8px;
		font-size: 1.125rem;
		font-weight: 600;
		transition: all 0.3s ease;
		box-shadow: 0 4px 16px rgba(255, 77, 166, 0.3);
	}

	.cta-button:hover {
		background: var(--theme-primary-hover, #ff2d95);
		transform: translateY(-2px);
		box-shadow: 0 6px 24px rgba(255, 77, 166, 0.4);
	}

	/* Animações */
	.fade {
		opacity: 0;
		transform: translateY(30px);
		animation: fadeUp 0.8s forwards;
	}

	.delay1 {
		animation-delay: 0.3s;
	}

	.delay2 {
		animation-delay: 0.6s;
	}

	.delay3 {
		animation-delay: 0.9s;
	}

	@keyframes fadeUp {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 768px) {
		.zefi-hero {
			min-height: 80vh;
		}

		.hero-content {
			text-align: center;
		}

		.hero-subtitle {
			font-size: 1.25rem;
		}

		.cta-button {
			padding: 0.875rem 2rem;
			font-size: 1rem;
		}
	}
</style>
